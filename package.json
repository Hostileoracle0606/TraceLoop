{
  "name": "traceloop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Causal firmware debugger — explains why a firmware test failed, not just that it did.",
  "scripts": {
    "test": "vitest run src/ && vitest run backend/",
    "test:watch": "vitest src/",
    "test:backend": "vitest run backend/",
    "typecheck": "tsc --noEmit",
    "backend:dev": "tsx watch backend/trpc/server.ts",
    "backend:start": "tsx backend/trpc/server.ts",
    "backboard:check": "node --env-file-if-exists=.env --import tsx spikes/backboard-feasibility/connectivity.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.1",
    "drizzle-kit": "^0.30.6",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/openai": "^4.0.16",
    "@sentry/node": "^10.66.0",
    "@supabase/supabase-js": "^2.110.7",
    "@trpc/server": "^11.18.0",
    "ai": "^7.0.31",
    "drizzle-orm": "^0.45.2",
    "inngest": "^4.13.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "zod": "^3.25.76"
  }
}
