# TraceLoop Backend Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Supabase Configuration
# =============================================================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# =============================================================================
# Database Configuration
# =============================================================================
# Direct database connection URL for Drizzle ORM
# Get this from Supabase: Settings > Database > Connection string > URI

DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# Modal Compute Plane
# =============================================================================
# The Modal endpoint for firmware build/simulate jobs
# Deploy with: modal deploy modal/app.py

MODAL_ENDPOINT=https://your-modal-endpoint.modal.run

# =============================================================================
# Inngest (Durable Job Execution)
# =============================================================================
# Get your event key from: https://app.inngest.com/env/production/settings/keys
# Leave INNGEST_BASE_URL empty for development (uses Inngest Dev Server)

INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_BASE_URL=http://localhost:8288

# =============================================================================
# LLM Configuration (Vercel AI SDK)
# =============================================================================
# Provider: 'anthropic' (default) or 'openai'
# Only the key for the selected provider is required.

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# =============================================================================
# Backboard Managed Conversation Runtime (opt-in)
# =============================================================================
# Set AGENT_RUNTIME_BACKBOARD_ENABLED=true to allow projects to opt into the
# Backboard managed conversation runtime. Generate a server-side API key and
# keep it out of source control. `backboard:check` is a read-only connectivity
# check; resource-creating feasibility probes additionally require
# BACKBOARD_LIVE=1.
# Get yours at: https://app.backboard.io/settings/api
#
# AGENT_RUNTIME_BACKBOARD_ENABLED=false
# BACKBOARD_API_KEY=your-backboard-api-key
# BACKBOARD_BASE_URL=https://app.backboard.io/api
# BACKBOARD_LIVE=0

# =============================================================================
# Server Configuration
# =============================================================================

PORT=3000
NODE_ENV=development
