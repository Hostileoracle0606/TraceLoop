{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@backend/*": ["./backend/*"],
      "@engine/*": ["./src/engine/*"],
      "@fixtures/*": ["./src/fixtures/*"]
    }
  },
  "include": ["src", "backend"]
}
